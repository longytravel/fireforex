{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(maturin *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(clippy *)",
      "Bash(pre-commit *)",
      "Bash(ruff *)",
      "Bash(bash scripts/finalize_pr.sh*)",
      "Bash(bash scripts/merge_pr.sh*)",
      "Bash(bash scripts/sync_main.sh*)",
      "Bash(bash scripts/daily_check.sh*)",
      "Bash(bash scripts/daily_parity_check.py*)",
      "PowerShell(git *)",
      "PowerShell(gh *)"
    ],
    "deny": [
      "Bash(git push*--no-verify*)",
      "Bash(git push -f*)",
      "Bash(git push --force*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit -n*)",
      "Bash(git commit*--amend*)",
      "Bash(git reset*--hard*)",
      "Bash(git checkout*--)",
      "Bash(git restore*--staged*.*)",
      "Bash(git clean*-f*)",
      "Bash(git branch*-D*)",
      "Bash(gh pr merge*--admin*)",
      "Bash(gh api*branches/main/protection*--method DELETE*)",
      "Bash(gh api*branches/main/protection*-X DELETE*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf \"C:*)",
      "Bash(rm -rf /c/*)",
      "Bash(uvicorn*)",
      "Bash(*uvicorn *)",
      "Bash(python*run.py web*)",
      "PowerShell(git commit*--no-verify*)",
      "PowerShell(git commit*--amend*)",
      "PowerShell(git reset*--hard*)",
      "PowerShell(Start-Process*uvicorn*)",
      "PowerShell(python*run.py web*)",
      "PowerShell(& *run.py web*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "Stop": []
  }
}
