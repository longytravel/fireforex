{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(maturin *)",
      "Bash(cargo *)",
      "Bash(rustfmt *)",
      "Bash(clippy *)",
      "Bash(pre-commit *)",
      "Bash(ruff *)",
      "PowerShell(git *)",
      "PowerShell(gh *)"
    ],
    "deny": [
      "Bash(git push*--force*)",
      "Bash(git push*--force-with-lease*)",
      "Bash(git push*-f*)",
      "Bash(git push*--no-verify*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git commit*-n*)",
      "Bash(git commit*--amend*)",
      "Bash(git reset*--hard*)",
      "Bash(git checkout*--)",
      "Bash(git restore*--staged*.*)",
      "Bash(git clean*-f*)",
      "Bash(git branch*-D*)",
      "Bash(gh pr merge*--admin*)",
      "Bash(gh api*branches/main/protection*--method DELETE*)",
      "Bash(gh api*branches/main/protection*-X DELETE*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf \"C:*)",
      "Bash(rm -rf /c/*)",
      "Bash(uvicorn*)",
      "Bash(*uvicorn *)",
      "Bash(python*run.py web*)",
      "PowerShell(git push*--force*)",
      "PowerShell(git push*-f*)",
      "PowerShell(git commit*--no-verify*)",
      "PowerShell(git commit*--amend*)",
      "PowerShell(git reset*--hard*)",
      "PowerShell(Start-Process*uvicorn*)",
      "PowerShell(python*run.py web*)",
      "PowerShell(& *run.py web*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/update-paperwork.sh\""
          }
        ]
      }
    ]
  }
}
