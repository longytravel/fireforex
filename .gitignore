# Playwright cache
.playwright-mcp/

# Superpowers brainstorm visual companion (mockup HTML, server state)
.superpowers/

# Editor / OS
.idea/
.vscode/
Thumbs.db
.DS_Store

# Claude Code: keep shared workflow files (settings.json, hooks, rules,
# commands) tracked; ignore machine-local state and runtime logs.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/hooks/log.txt

# Local dev scaffolding
artifacts/_kill.ps1
artifacts/server.log
artifacts/server.err
artifacts/_pre_pr_diff.patch
artifacts/review-*.md
artifacts/_pr_*.md
artifacts/_*.log
artifacts/_codex_*

# Live-parity runner — VPS-only creds + ephemeral runtime state.
# Never commit these: they contain MT5 credentials and ticket/plan logs.
.env.live
.env.live.*
artifacts/live/
artifacts/calibration/
artifacts/parity/
artifacts/replay/

# Transient laptop-side staging for VPS artifact sync + one-off diagnostics.
artifacts/_incoming/
artifacts/live_archive_*/
artifacts/_*_rerun_*.log
artifacts/diag_*.txt
scripts/_tmp_*.py
