target/
*.pyd
*.so

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Run artefacts (keep history.csv + baseline.json; drop heavy npz)
artifacts/runs/
artifacts/signal_cache/
artifacts/comparison.html
